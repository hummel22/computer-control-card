{
  "name": "computer-control-card",
  "version": "0.1.0",
  "description": "Frontend-only Home Assistant Lovelace card for controlling computers remotely.",
  "type": "module",
  "main": "dist/computer-control-card.js",
  "module": "dist/computer-control-card.js",
  "files": [
    "dist",
    "hacs.json",
    "README.md"
  ],
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "demo": "vite --host 0.0.0.0 --open /demo/",
    "build": "vite build",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "tsx --test tests/unit/*.test.ts",
    "setup:e2e": "playwright install --with-deps chromium",
    "pretest:e2e": "npm run setup:e2e",
    "test:e2e": "playwright test",
    "pretest:visual": "npm run setup:e2e",
    "test:visual": "playwright test --grep @screenshots",
    "prescreenshots": "npm run setup:e2e",
    "screenshots": "playwright test --grep @screenshots"
  },
  "keywords": [
    "home-assistant",
    "lovelace",
    "hacs",
    "custom-card",
    "lit"
  ],
  "license": "MIT",
  "dependencies": {
    "lit": "^3.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.0.10",
    "tsx": "^4.23.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  }
}
